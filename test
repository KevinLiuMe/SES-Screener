# 5. CREATE BLOOMBERG UNIVERSE
# -----------------------------

universe = bq.univ.list(TICKERS)


# -----------------------------
# 6. REQUEST HISTORICAL DATA
# -----------------------------
#
# We request one year of:
#   - Last price
