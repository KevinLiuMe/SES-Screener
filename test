def flatten_columns(df: pd.DataFrame) -> pd.DataFrame:
    """
    Convert multi-index or irregular Bloomberg column names
    into simple strings.
    """
    output = df.copy()

    if isinstance(output.columns, pd.MultiIndex):
        output.columns = [
            "_".join(
                str(item).strip()
                for item in column
                if str(item).strip() not in ("", "None")
            )
            for column in output.columns
        ]
    else:
        output.columns = [str(column).strip() for column in output.columns]

    return output


def identify_column(
    columns,
    possible_terms,
    exclude_terms=None,
):
    """
    Search column names for likely matches.

    Bloomberg response column names can vary slightly by environment.
    """
    exclude_terms = exclude_terms or []

    for column in columns:
        normalized = str(column).lower()

        contains_required_term = any(
            term.lower() in normalized
            for term in possible_terms
        )

        contains_excluded_term = any(
            term.lower() in normalized
            for term in exclude_terms
        )

        if contains_required_term and not contains_excluded_term:
            return column

    return None


def percentile_score(
    series: pd.Series,
    higher_is_better: bool = True,
) -> pd.Series:
    """
    Convert a numeric series into a percentile score from 0 to 100.
    """
    numeric = pd.to_numeric(series, errors="coerce")

    score = numeric.rank(
        pct=True,
        method="average",
    ) * 100

    if not higher_is_better:
        score = 100 - score

    return score


def annualized_realized_volatility(
    returns: pd.Series,
    window: int = 20,
) -> float:
    """
    Calculate annualized realized volatility from daily returns.
    """
    clean_returns = returns.dropna()

    if len(clean_returns) < window:
        return np.nan

    recent_returns = clean_returns.tail(window)

    return recent_returns.std(ddof=1) * np.sqrt(252)


def safe_float(value, default=np.nan):
    """
    Convert a value to float without breaking the program.
    """
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def create_reason(row: pd.Series) -> str:
    """
    Produce a readable explanation for why a company was flagged.
    """
    reasons = []

    below_high = row.get("Pct_Below_52W_High")
    vol_score = row.get("Volatility_Score")
    return_3m = row.get("Return_3M")
    liquidity_score = row.get("Liquidity_Score")

    if pd.notna(below_high):
        if below_high <= 3:
            reasons.append(
                f"only {below_high:.1f}% below its 52-week high"
            )
        elif below_high <= 10:
            reasons.append(
                f"{below_high:.1f}% below its 52-week high"
            )

    if pd.notna(vol_score) and vol_score >= 75:
        reasons.append("elevated realized volatility")

    if pd.notna(return_3m):
        if return_3m >= 0.20:
            reasons.append(
                f"strong three-month return of {return_3m:.1%}"
            )
        elif return_3m <= -0.20:
            reasons.append(
                f"large three-month decline of {return_3m:.1%}"
            )

    if pd.notna(liquidity_score) and liquidity_score >= 75:
        reasons.append("strong trading liquidity")

    if not reasons:
        return "No unusually strong screening signal."

    return "; ".join(reasons).capitalize() + "."


def collar_payoff(
    spot: float,
    put_strike: float,
    call_strike: float,
    shares: float = 1.0,
    put_premium: float = 0.0,
    call_premium: float = 0.0,
    lower_spot_multiplier: float = 0.50,
    upper_spot_multiplier: float = 1.50,
    number_of_points: int = 301,
) -> pd.DataFrame:
    """
    Calculate terminal values for:

        Long stock
        + Long put
        - Short call

    Premiums are per share.

    This is an illustrative terminal-payoff model and does not include:
        - Financing
        - Dividends
        - Stock borrow
        - Taxes
        - Early exercise
        - Counterparty adjustments
        - Transaction costs
    """
    terminal_prices = np.linspace(
        spot * lower_spot_multiplier,
        spot * upper_spot_multiplier,
        number_of_points,
    )

    stock_terminal_value = terminal_prices

    long_put_value = np.maximum(
        put_strike - terminal_prices,
        0,
    )

    short_call_value = -np.maximum(
        terminal_prices - call_strike,
        0,
    )

    net_option_premium = call_premium - put_premium

    collar_value_per_share = (
        stock_terminal_value
        + long_put_value
        + short_call_value
        + net_option_premium
    )

    return pd.DataFrame(
        {
            "Terminal_Stock_Price": terminal_prices,
            "Unhedged_Value": terminal_prices * shares,
            "Collar_Value": collar_value_per_share * shares,
            "Put_Value": long_put_value * shares,
            "Short_Call_Value": short_call_value * shares,
        }
    )


