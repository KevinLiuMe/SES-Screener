        "Realized_Vol_20D": "20D Realized Vol (%)",
        "Return_3M": "3M Return (%)",
        "Average_Daily_Value_Traded_20D": (
            "20D Avg Daily Value Traded ($mm)"
        ),
        "Opportunity_Score": "Opportunity Score",
