#
# If "px_volume" is not recognized in your BQuant environment,
# type:
#
#     bq.data.
#
# and press Tab, then search for "volume".
# -----------------------------

date_range = bq.func.range("-1Y", "0D")

historical_items = {
    "Price": bq.data.px_last(
        dates=date_range,
        fill="prev",
    ),
    "Volume": bq.data.px_volume(
        dates=date_range,
        fill="prev",
    ),
}

historical_request = bql.Request(
    universe,
    historical_items,
)

print("Requesting Bloomberg historical data...")

historical_response = bq.execute(historical_request)

historical_df = bql.combined_df(
    historical_response
).reset_index()

historical_df = flatten_columns(historical_df)

print("Historical data returned.")
print("Returned columns:")
print(historical_df.columns.tolist())


# -----------------------------
# 7. IDENTIFY RETURNED COLUMNS
# -----------------------------

ticker_column = identify_column(
    historical_df.columns,
    possible_terms=[
        "id",
        "security",
        "ticker",
    ],
    exclude_terms=[
        "currency",
    ],
)

date_column = identify_column(
    historical_df.columns,
    possible_terms=[
        "date",
    ],
)

price_column = identify_column(
    historical_df.columns,
    possible_terms=[
        "price",
        "px_last",
    ],
)

volume_column = identify_column(
    historical_df.columns,
    possible_terms=[
        "volume",
        "px_volume",
    ],
)

if ticker_column is None:
    raise ValueError(
        "Could not identify the ticker/security column. "
        f"Returned columns were: {historical_df.columns.tolist()}"
    )

if date_column is None:
    raise ValueError(
        "Could not identify the date column. "
        f"Returned columns were: {historical_df.columns.tolist()}"
    )

if price_column is None:
    raise ValueError(
        "Could not identify the price column. "
        f"Returned columns were: {historical_df.columns.tolist()}"
    )

if volume_column is None:
    raise ValueError(
        "Could not identify the volume column. "
        "Check the Bloomberg volume field name using BQL autocomplete. "
        f"Returned columns were: {historical_df.columns.tolist()}"
    )

print("\nDetected columns:")
print(f"Ticker: {ticker_column}")
print(f"Date:   {date_column}")
print(f"Price:  {price_column}")
print(f"Volume: {volume_column}")


# -----------------------------
# 8. CLEAN HISTORICAL DATA
# -----------------------------

history = historical_df[
    [
        ticker_column,
        date_column,
        price_column,
        volume_column,
    ]
].copy()

history.columns = [
    "Ticker",
    "Date",
    "Price",
    "Volume",
]

history["Date"] = pd.to_datetime(
    history["Date"],
    errors="coerce",
)

history["Price"] = pd.to_numeric(
    history["Price"],
    errors="coerce",
)

history["Volume"] = pd.to_numeric(
    history["Volume"],
    errors="coerce",
)

history = history.dropna(
    subset=[
        "Ticker",
        "Date",
        "Price",
    ]
)

history = history.sort_values(
    [
        "Ticker",
        "Date",
    ]
)

# Occasionally a Bloomberg response can contain duplicate observations.
history = history.drop_duplicates(
    subset=[
        "Ticker",
        "Date",
    ],
    keep="last",
)

print(f"\nUsable historical observations: {len(history):,}")
print(f"Usable securities: {history['Ticker'].nunique():,}")


# -----------------------------
# 9. CALCULATE SECURITY METRICS
# -----------------------------

security_metrics = []

for ticker, ticker_history in history.groupby("Ticker"):

    ticker_history = ticker_history.sort_values("Date").copy()

    prices = ticker_history["Price"].dropna()
    volumes = ticker_history["Volume"].dropna()

    if len(prices) < 30:
        print(
            f"Skipping {ticker}: "
            f"only {len(prices)} usable price observations."
        )
        continue

    current_price = prices.iloc[-1]
    high_52_week = prices.max()
    low_52_week = prices.min()

    pct_below_high = (
        (high_52_week - current_price)
        / high_52_week
    ) * 100

    daily_returns = prices.pct_change()

    realized_vol_20d = annualized_realized_volatility(
        daily_returns,
        window=20,
    )

    realized_vol_60d = annualized_realized_volatility(
        daily_returns,
        window=60,
    )

    # Approximately 21 trading days per month.
    if len(prices) >= 64:
        return_3m = (
            current_price / prices.iloc[-64]
        ) - 1
    else:
        return_3m = np.nan

    if len(prices) >= 127:
        return_6m = (
            current_price / prices.iloc[-127]
        ) - 1
    else:
        return_6m = np.nan

    if len(prices) >= 252:
        return_1y = (
            current_price / prices.iloc[-252]
        ) - 1
    else:
        return_1y = (
            current_price / prices.iloc[0]
        ) - 1

    average_volume_20d = (
        volumes.tail(20).mean()
        if len(volumes) > 0
        else np.nan
    )

    average_volume_60d = (
        volumes.tail(60).mean()
        if len(volumes) > 0
        else np.nan
    )

    average_daily_value_traded_20d = (
        ticker_history
        .assign(
            Daily_Value_Traded=(
                ticker_history["Price"]
                * ticker_history["Volume"]
            )
        )["Daily_Value_Traded"]
        .dropna()
        .tail(20)
        .mean()
    )

    security_metrics.append(
        {
            "Ticker": ticker,
            "Price": current_price,
            "52W_High": high_52_week,
            "52W_Low": low_52_week,
            "Pct_Below_52W_High": pct_below_high,
            "Realized_Vol_20D": realized_vol_20d,
            "Realized_Vol_60D": realized_vol_60d,
            "Return_3M": return_3m,
            "Return_6M": return_6m,
            "Return_1Y": return_1y,
            "Average_Volume_20D": average_volume_20d,
            "Average_Volume_60D": average_volume_60d,
            "Average_Daily_Value_Traded_20D": (
                average_daily_value_traded_20d
            ),
            "Last_Data_Date": ticker_history["Date"].max(),
            "Observation_Count": len(prices),
        }
    )

metrics = pd.DataFrame(security_metrics)

if metrics.empty:
    raise ValueError(
        "No usable security metrics were produced. "
        "Inspect the historical Bloomberg response and field names."
    )


# -----------------------------
# 10. CREATE FACTOR SCORES
# -----------------------------

# Stocks closer to their 52-week highs receive higher scores.
metrics["High_Proximity_Score"] = percentile_score(
    metrics["Pct_Below_52W_High"],
    higher_is_better=False,
)

# Higher realized volatility receives a higher score.
metrics["Volatility_Score"] = percentile_score(
    metrics["Realized_Vol_20D"],
    higher_is_better=True,
)

# Stronger three-month returns receive higher scores.
metrics["Recent_Return_Score"] = percentile_score(
    metrics["Return_3M"],
    higher_is_better=True,
)

# Higher average daily dollar trading volume receives a higher score.
metrics["Liquidity_Score"] = percentile_score(
    metrics["Average_Daily_Value_Traded_20D"],
    higher_is_better=True,
)


# -----------------------------
# 11. CREATE OPPORTUNITY SCORE
# -----------------------------

metrics["Opportunity_Score"] = (
    WEIGHTS["high_proximity"]
    * metrics["High_Proximity_Score"]
    +
    WEIGHTS["realized_volatility"]
    * metrics["Volatility_Score"]
    +
    WEIGHTS["recent_return"]
    * metrics["Recent_Return_Score"]
    +
    WEIGHTS["liquidity"]
    * metrics["Liquidity_Score"]
)


# -----------------------------
# 12. ADD READABLE EXPLANATIONS
# -----------------------------

metrics["Why_Flagged"] = metrics.apply(
    create_reason,
    axis=1,
)


