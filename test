payoff_chart.show()


# -----------------------------
# 19. TERMINAL-SCENARIO TABLE
# -----------------------------

scenario_prices = [
    selected_spot * 0.50,
    selected_spot * 0.75,
    put_strike,
    selected_spot,
    call_strike,
    selected_spot * 1.25,
    selected_spot * 1.50,
]

scenario_rows = []

for terminal_price in scenario_prices:

    stock_value = terminal_price * DEFAULT_SHARES

    collar_value = (
        terminal_price
        + max(put_strike - terminal_price, 0)
        - max(terminal_price - call_strike, 0)
    ) * DEFAULT_SHARES

    scenario_rows.append(
        {
            "Terminal Stock Price": terminal_price,
            "Unhedged Position Value": stock_value,
            "Collar Position Value": collar_value,
            "Difference": collar_value - stock_value,
        }
    )

scenario_table = pd.DataFrame(scenario_rows)

scenario_table["Terminal Stock Price"] = (
    scenario_table["Terminal Stock Price"].round(2)
)

for column in [
    "Unhedged Position Value",
    "Collar Position Value",
    "Difference",
]:
    scenario_table[column] = scenario_table[column].round(0)

print("\nILLUSTRATIVE TERMINAL-SCENARIO TABLE")
display(scenario_table)

