# ============================================================
# BQUANT / BQL FIELD SMOKE TEST
#
# Tests Bloomberg calls one at a time so one broken field
# does not stop the rest of the notebook.
# ============================================================

import bql
import pandas as pd
import traceback
from IPython.display import display


# ------------------------------------------------------------
# 1. CONNECT TO BQL
# ------------------------------------------------------------

bq = bql.Service()

TEST_TICKER = "AAPL US Equity"
TEST_UNIVERSE = bq.univ.list([TEST_TICKER])

print("BQL service created successfully.")
print(f"Testing Bloomberg calls using: {TEST_TICKER}")


# ------------------------------------------------------------
# 2. HELPER FUNCTION
# ------------------------------------------------------------

test_results = []


def run_bql_test(
    test_name,
    item_builder,
    universe=TEST_UNIVERSE,
    show_rows=5,
):
    """
    Build and execute one BQL field request.

    item_builder must be a function with no arguments that returns
    a BQL data item, for example:

        lambda: bq.data.px_last()
    """

    print("\n" + "=" * 70)
    print(f"TEST: {test_name}")
    print("=" * 70)

    try:
        # Build the field separately so syntax errors are caught.
        item = item_builder()

        request = bql.Request(
            universe,
            {
                test_name: item
            },
        )

        response = bq.execute(request)

        dataframe = bql.combined_df(
            response
        ).reset_index()

        print("STATUS: PASS")
        print(f"Rows returned: {len(dataframe)}")
        print("Columns returned:")
        print(dataframe.columns.tolist())

        if dataframe.empty:
            print("WARNING: Request succeeded but returned no rows.")
        else:
            display(dataframe.head(show_rows))

        non_null_count = 0

        if not dataframe.empty:
            candidate_columns = [
                column
                for column in dataframe.columns
                if str(column).lower()
                not in {
                    "id",
                    "date",
                    "currency",
                    "secondary_name",
                    "revision_date",
                }
            ]

            for column in candidate_columns:
                non_null_count += dataframe[column].notna().sum()

        test_results.append(
            {
                "Test": test_name,
                "Status": "PASS",
                "Rows": len(dataframe),
                "Non-Null Values": non_null_count,
                "Error": "",
            }
        )

        return dataframe

    except Exception as error:

        print("STATUS: FAIL")
        print("Error type:", type(error).__name__)
        print("Error message:")
        print(str(error))

        test_results.append(
            {
                "Test": test_name,
                "Status": "FAIL",
                "Rows": 0,
                "Non-Null Values": 0,
                "Error": str(error),
            }
        )

        return None


