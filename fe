# ------------------------------------------------------------

def update_selected_security(change=None):
    results = app_state.get("results")

    if results is None:
        return

    ticker = security_selector.value

    if not ticker:
        return

    selected = results[
        results["Ticker"] == ticker
    ]

    if selected.empty:
        return

    row = selected.iloc[0]

    app_state["selected_ticker"] = ticker

    spot = safe_number(
        row["Price"]
    )

    if pd.isna(spot):
        return

    with security_summary_output:
        clear_output(wait=True)
        display_security_summary(row)

    with factor_output:
        clear_output(wait=True)

        factor_figure = create_factor_chart(
            row
        )

        factor_figure.show()

    with payoff_output:
        clear_output(wait=True)

        payoff_figure = create_collar_chart(
            ticker=ticker,
            spot=spot,
            put_strike_pct=put_strike_input.value,
            call_strike_pct=call_strike_input.value,
            shares=shares_input.value,
        )

        payoff_figure.show()

    with scenario_output:
        clear_output(wait=True)

        scenario_table = create_scenario_table(
            spot=spot,
            put_strike_pct=put_strike_input.value,
            call_strike_pct=call_strike_input.value,
            shares=shares_input.value,
        )

        styled_scenario_table = (
            scenario_table.style
            .set_properties(
                **{
                    "background-color": COLORS["panel"],
                    "color": COLORS["text"],
                    "border-color": COLORS["border"],
                    "padding": "8px",
                }
            )
            .set_table_styles(
                [
                    {
                        "selector": "th",
                        "props": [
                            (
                                "background-color",
                                COLORS["panel_secondary"],
                            ),
                            (
                                "color",
                                COLORS["yellow"],
                            ),
                            (
                                "border",
                                f"1px solid {COLORS['border']}",
                            ),
                            (
                                "padding",
                                "8px",
                            ),
                        ],
                    }
                ]
            )
            .format(
                {
                    "Terminal Stock Price": "${:,.2f}",
                    "Unhedged Value": "${:,.0f}",
                    "Collar Value": "${:,.0f}",
                    "Collar Minus Unhedged": "${:,.0f}",
                }
            )
        )

        display(
            styled_scenario_table
        )


# ------------------------------------------------------------
# 17. RUN SCREEN CALLBACK
# ------------------------------------------------------------

def refresh_dashboard(button=None):
    run_button.disabled = True
    export_button.disabled = True

    status_widget.value = (
        f"<span style='color:{COLORS['yellow']};'>"
        "Running Bloomberg screen..."
        "</span>"
    )

    with message_output:
        clear_output(wait=True)

    try:
        tickers = parse_tickers(
            ticker_input.value
        )

        if not tickers:
            raise ValueError(
                "Enter at least one Bloomberg ticker."
            )

        normalized_weights = normalize_weights(
            high_weight=high_weight_input.value,
            volatility_weight=volatility_weight_input.value,
            return_weight=return_weight_input.value,
            liquidity_weight=liquidity_weight_input.value,
        )

        results, history = run_opportunity_screen(
            tickers=tickers,
            top_n=top_n_input.value,
            high_proximity_weight=(
                normalized_weights[
                    "high_proximity"
                ]
            ),
            volatility_weight=(
                normalized_weights[
                    "realized_volatility"
                ]
            ),
            return_weight=(
                normalized_weights[
                    "recent_return"
                ]
            ),
            liquidity_weight=(
                normalized_weights[
                    "liquidity"
                ]
            ),
        )

        if results is None or results.empty:
            raise ValueError(
                "The screen returned no usable results."
            )

        results = (
            results
            .sort_values(
                "Opportunity_Score",
                ascending=False,
                na_position="last",
            )
            .reset_index(drop=True)
        )

        app_state["results"] = results
        app_state["history"] = history

        ticker_options = (
            results["Ticker"]
            .dropna()
            .astype(str)
            .tolist()
        )

        security_selector.options = ticker_options

        with table_output:
            clear_output(wait=True)

            formatted_table = format_results_table(
                results=results,
                top_n=top_n_input.value,
            )

            display(
                style_results_table(
                    formatted_table
                )
            )

        with ranking_output:
            clear_output(wait=True)

            ranking_figure = create_ranking_chart(
                results=results,
                top_n=top_n_input.value,
            )

            ranking_figure.show()

        if ticker_options:
            security_selector.value = ticker_options[0]
            update_selected_security()

        status_widget.value = (
            f"<span style='color:{COLORS['green']};'>"
            f"Complete — {len(results)} securities analyzed."
            "</span>"
        )

        export_button.disabled = False

    except Exception as error:
        status_widget.value = (
            f"<span style='color:{COLORS['red']};'>"
            f"Error: {type(error).__name__}"
            "</span>"
        )

        with message_output:
            clear_output(wait=True)

            print(
                f"{type(error).__name__}: {error}"
            )

    finally:
        run_button.disabled = False


