def format_results_table(results, top_n):
    """
    Build a readable display table from the raw results.
    """
    required_columns = [
        "Ticker",
        "Price",
        "Pct_Below_52W_High",
        "Realized_Vol_20D",
        "Return_3M",
        "Average_Volume_20D",
        "Average_Daily_Value_Traded_20D",
        "Opportunity_Score",
        "Why_Flagged",
    ]

    missing_columns = [
        column
        for column in required_columns
        if column not in results.columns
    ]

    if missing_columns:
        raise ValueError(
            "The results dataframe is missing these columns: "
            + ", ".join(missing_columns)
        )

    table = (
        results
        .head(top_n)
        .loc[:, required_columns]
        .copy()
    )

    table["Price"] = table["Price"].round(2)

    table["Pct_Below_52W_High"] = (
        table["Pct_Below_52W_High"]
        .round(1)
    )

    table["Realized_Vol_20D"] = (
        table["Realized_Vol_20D"]
        * 100
    ).round(1)

    table["Return_3M"] = (
        table["Return_3M"]
        * 100
    ).round(1)

    table["Average_Volume_20D"] = (
        table["Average_Volume_20D"]
        / 1_000_000
    ).round(2)

    table["Average_Daily_Value_Traded_20D"] = (
        table["Average_Daily_Value_Traded_20D"]
        / 1_000_000
    ).round(1)

    table["Opportunity_Score"] = (
        table["Opportunity_Score"]
        .round(1)
    )

    table = table.rename(
        columns={
            "Pct_Below_52W_High":
                "% Below 52W High",

            "Realized_Vol_20D":
                "20D Realized Vol (%)",

            "Return_3M":
                "3M Return (%)",

            "Average_Volume_20D":
                "20D Avg Volume (mm)",

            "Average_Daily_Value_Traded_20D":
                "20D Avg Value Traded ($mm)",

            "Opportunity_Score":
                "Score",

            "Why_Flagged":
                "Why Flagged",
        }
    )

    table.index = range(1, len(table) + 1)
    table.index.name = "Rank"

    return table


