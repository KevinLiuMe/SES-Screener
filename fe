def parse_tickers(text):
    """
    Convert one-ticker-per-line input into a unique list.
    """
    tickers = []

    for line in text.splitlines():
        ticker = line.strip()

        if ticker:
            tickers.append(ticker)

    # Preserve order while removing duplicates.
    return list(dict.fromkeys(tickers))


def safe_number(value, default=np.nan):
    """
    Safely convert a value to float.
    """
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def safe_metric(row, column, default=np.nan):
    """
    Safely retrieve a metric from a pandas row.
    """
    if column not in row.index:
        return default

    return row[column]


def format_money(value, decimals=2):
    if pd.isna(value):
        return "N/A"

    return f"${value:,.{decimals}f}"


def format_percent(value, decimals=1):
    if pd.isna(value):
        return "N/A"

    return f"{value:.{decimals}%}"


def format_number(value, decimals=1):
    if pd.isna(value):
        return "N/A"

    return f"{value:,.{decimals}f}"


def format_integer(value):
    if pd.isna(value):
        return "N/A"

    return f"{value:,.0f}"


def normalize_weights(
    high_weight,
    volatility_weight,
    return_weight,
    liquidity_weight,
):
    """
    Return normalized weights that sum to one.
    """
    raw_weights = np.array(
        [
            high_weight,
            volatility_weight,
            return_weight,
            liquidity_weight,
        ],
        dtype=float,
    )

    total = raw_weights.sum()

    if total <= 0:
        raise ValueError(
            "At least one factor weight must be greater than zero."
        )

    normalized = raw_weights / total

    return {
        "high_proximity": normalized[0],
        "realized_volatility": normalized[1],
        "recent_return": normalized[2],
        "liquidity": normalized[3],
    }


