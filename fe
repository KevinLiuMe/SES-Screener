def export_results(button=None):
    results = app_state.get("results")

    if results is None or results.empty:
        status_widget.value = (
            f"<span style='color:{COLORS['red']};'>"
            "No results available to export."
            "</span>"
        )
        return

    filename = (
        "strategic_equity_opportunity_screen.csv"
    )

    results.to_csv(
        filename,
        index=False,
    )

    status_widget.value = (
        f"<span style='color:{COLORS['green']};'>"
        f"Exported to {filename}"
        "</span>"
    )


