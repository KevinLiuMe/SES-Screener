    cards = [
        (
            "Current Price",
            format_money(
                safe_metric(row, "Price")
            ),
        ),
        (
            "Opportunity Score",
            format_number(
                safe_metric(row, "Opportunity_Score"),
                decimals=1,
            ),
        ),
        (
            "Below 52W High",
            (
                format_number(
                    safe_metric(
                        row,
                        "Pct_Below_52W_High",
                    ),
                    decimals=1,
                )
                + "%"
                if pd.notna(
                    safe_metric(
                        row,
                        "Pct_Below_52W_High",
                    )
                )
                else "N/A"
            ),
        ),
        (
            "20D Realized Vol",
            format_percent(
                safe_metric(
                    row,
                    "Realized_Vol_20D",
                )
            ),
        ),
        (
            "3M Return",
            format_percent(
                safe_metric(
                    row,
                    "Return_3M",
                )
            ),
        ),
        (
            "20D Avg Volume",
            format_integer(
                safe_metric(
                    row,
                    "Average_Volume_20D",
                )
            ),
        ),
    ]

    card_html = ""

    for label, value in cards:
        card_html += f"""
        <div style="
            background:{COLORS['panel_secondary']};
            border:1px solid {COLORS['border']};
            padding:10px 12px;
            min-width:135px;
            flex:1;
        ">
            <div style="
                color:{COLORS['muted']};
                font-size:10px;
                text-transform:uppercase;
            ">
                {label}
            </div>

            <div style="
                color:{COLORS['text']};
                font-size:18px;
                font-weight:700;
                margin-top:4px;
            ">
                {value}
            </div>
        </div>
        """

    reason = safe_metric(
        row,
        "Why_Flagged",
        default="No explanation available.",
    )

    summary_html = f"""
    <div style="
        font-family:Arial, sans-serif;
        background:{COLORS['panel']};
        color:{COLORS['text']};
    ">
        <div style="
            color:{COLORS['yellow']};
            font-size:19px;
            font-weight:700;
            margin-bottom:10px;
        ">
            {ticker}
        </div>

        <div style="
            display:flex;
            gap:8px;
            flex-wrap:wrap;
        ">
            {card_html}
        </div>

        <div style="
            background:{COLORS['background']};
            border-left:4px solid {COLORS['yellow']};
            padding:10px 12px;
            margin-top:12px;
            color:{COLORS['text']};
            font-size:12px;
        ">
            <strong>Why flagged:</strong> {reason}
        </div>
    </div>
    """

    display(
        widgets.HTML(
            value=summary_html
        )
    )


