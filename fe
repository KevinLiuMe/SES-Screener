        results
        .dropna(subset=["Opportunity_Score"])
        .head(top_n)
        .sort_values(
            "Opportunity_Score",
            ascending=True,
        )
        .copy()
    )

    figure = go.Figure()

    figure.add_trace(
        go.Bar(
            x=chart_data["Opportunity_Score"],
            y=chart_data["Ticker"],
            orientation="h",
            text=chart_data[
                "Opportunity_Score"
            ].round(1),
            textposition="outside",
            marker=dict(
                color=chart_data["Opportunity_Score"],
                colorscale=[
                    [0.0, "#38424d"],
                    [0.5, "#92701d"],
