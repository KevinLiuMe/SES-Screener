# 9. SCENARIO TABLE
# ------------------------------------------------------------

def create_scenario_table(
    spot,
    put_strike_pct,
    call_strike_pct,
    shares,
):
    """
    Create a simple terminal-value scenario table.
    """
    put_strike = spot * put_strike_pct
    call_strike = spot * call_strike_pct

    scenario_prices = [
        spot * 0.50,
        spot * 0.75,
        put_strike,
        spot,
        call_strike,
        spot * 1.25,
        spot * 1.50,
    ]

    scenario_rows = []

    for terminal_price in scenario_prices:

        unhedged_value = terminal_price * shares

        collar_value = (
            terminal_price
            + max(
                put_strike - terminal_price,
                0,
            )
            - max(
                terminal_price - call_strike,
                0,
            )
        ) * shares

        scenario_rows.append(
            {
                "Terminal Stock Price": terminal_price,
                "Unhedged Value": unhedged_value,
                "Collar Value": collar_value,
                "Collar Minus Unhedged": (
                    collar_value - unhedged_value
                ),
            }
        )

    scenario_table = pd.DataFrame(
        scenario_rows
    )

    return scenario_table


