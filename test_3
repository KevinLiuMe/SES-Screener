# ============================================================
# STRATEGIC EQUITY SOLUTIONS
# COLLAR / MONETIZATION OPPORTUNITY SCREENER
#
# BQuant / BQL MVP
#
# Bloomberg fields required:
#   bq.data.px_last()
#   bq.data.px_volume()
#
# Main signals:
#   1. Proximity to 52-week high
#   2. 20-day realized volatility
#   3. Three-month stock return
#   4. Average daily dollar liquidity
#
# Important:
#   - Price and volume are requested separately.
#   - Volume is not forward-filled.
#   - The output is illustrative and is not executable pricing.
# ============================================================


# ------------------------------------------------------------
# 1. IMPORTS
# ------------------------------------------------------------

import bql
import pandas as pd
import numpy as np
import plotly.graph_objects as go

from IPython.display import display


# ------------------------------------------------------------
# 2. CONNECT TO BQL
# ------------------------------------------------------------

bq = bql.Service()

print("BQL service connected successfully.")


# ------------------------------------------------------------
# 3. USER SETTINGS
# ------------------------------------------------------------


def run_opportunity_screen(
    tickers,
    top_n=10,
    high_proximity_weight=0.35,
    volatility_weight=0.35,
    return_weight=0.15,
    liquidity_weight=0.15,
):


    TICKERS = [
        "AAPL US Equity",
        "MSFT US Equity",
        "AMZN US Equity",
        "META US Equity",
        "NVDA US Equity",
        "GOOGL US Equity",
        "TSLA US Equity",
        "EQIX US Equity",
        "CRM US Equity",
        "AVGO US Equity",
    ]
    
    TOP_N = 10
    
    # Weights must add to 1.00.
    WEIGHTS = {
        "high_proximity": 0.35,
        "realized_volatility": 0.35,
        "recent_return": 0.15,
        "liquidity": 0.15,
    }
    
    # Illustrative collar settings.
    DEFAULT_PUT_STRIKE_PCT = 0.90
    DEFAULT_CALL_STRIKE_PCT = 1.15
    DEFAULT_SHARES = 1_000_000
    
    
    # ------------------------------------------------------------
    # 4. HELPER FUNCTIONS
    # ------------------------------------------------------------
    
    def flatten_columns(df: pd.DataFrame) -> pd.DataFrame:
        """
        Convert MultiIndex or irregular Bloomberg columns
        into simple string column names.
        """
        output = df.copy()
    
        if isinstance(output.columns, pd.MultiIndex):
            output.columns = [
                "_".join(
                    str(item).strip()
                    for item in column
                    if str(item).strip() not in ("", "None")
                )
                for column in output.columns
            ]
        else:
            output.columns = [
                str(column).strip()
                for column in output.columns
            ]
    
        return output
    
    
    def identify_column(
        columns,
        possible_terms,
        exclude_terms=None,
    ):
        """
        Identify a returned Bloomberg column by looking for
        one of the supplied terms in its name.
        """
        exclude_terms = exclude_terms or []
    
        for column in columns:
            normalized = str(column).lower()
    
            contains_required_term = any(
                term.lower() in normalized
                for term in possible_terms
            )
    
            contains_excluded_term = any(
                term.lower() in normalized
                for term in exclude_terms
            )
    
            if contains_required_term and not contains_excluded_term:
                return column
    
        return None
    
    
    def percentile_score(
        series: pd.Series,
        higher_is_better: bool = True,
    ) -> pd.Series:
        """
        Convert numeric observations into percentile scores
        ranging from 0 to 100.
        """
        numeric = pd.to_numeric(
            series,
            errors="coerce",
        )
    
        score = numeric.rank(
            pct=True,
            method="average",
        ) * 100
    
        if not higher_is_better:
            score = 100 - score
    
        return score
    
    
    def annualized_realized_volatility(
        returns: pd.Series,
        window: int,
    ) -> float:
        """
        Calculate annualized realized volatility from daily returns.
        """
        clean_returns = returns.dropna()
    
        if len(clean_returns) < window:
            return np.nan
    
        return (
            clean_returns
            .tail(window)
            .std(ddof=1)
            * np.sqrt(252)
        )
    
    
    def safe_float(value, default=np.nan):
        """
        Safely convert a value to a float.
        """
        try:
            return float(value)
        except (TypeError, ValueError):
            return default
    
    
    def create_reason(row: pd.Series) -> str:
        """
        Generate a readable explanation for each screening result.
        """
        reasons = []
    
        pct_below_high = row.get("Pct_Below_52W_High")
        volatility_score = row.get("Volatility_Score")
        return_3m = row.get("Return_3M")
        liquidity_score = row.get("Liquidity_Score")
    
        if pd.notna(pct_below_high):
            if pct_below_high <= 3:
                reasons.append(
                    f"only {pct_below_high:.1f}% below its 52-week high"
                )
            elif pct_below_high <= 10:
                reasons.append(
                    f"{pct_below_high:.1f}% below its 52-week high"
                )
    
        if (
            pd.notna(volatility_score)
            and volatility_score >= 75
        ):
            reasons.append(
                "elevated realized volatility"
            )
    
        if pd.notna(return_3m):
            if return_3m >= 0.20:
                reasons.append(
                    f"strong three-month return of {return_3m:.1%}"
                )
            elif return_3m <= -0.20:
                reasons.append(
                    f"large three-month decline of {return_3m:.1%}"
                )
    
        if (
            pd.notna(liquidity_score)
            and liquidity_score >= 75
        ):
            reasons.append(
                "strong trading liquidity"
            )
    
        if not reasons:
            return "No unusually strong screening signal."
    
        return "; ".join(reasons).capitalize() + "."
    
    
    def collar_payoff(
        spot: float,
        put_strike: float,
        call_strike: float,
        shares: float = 1.0,
        put_premium: float = 0.0,
        call_premium: float = 0.0,
        lower_spot_multiplier: float = 0.50,
        upper_spot_multiplier: float = 1.50,
        number_of_points: int = 301,
    ) -> pd.DataFrame:
        """
        Calculate the terminal value of:
    
            Long stock
            + Long put
            - Short call
    
        Premiums are expressed per share.
    
        This illustrative payoff excludes:
            - Financing costs
            - Dividends
            - Stock borrow
            - Taxes
            - Early exercise
            - Transaction costs
            - Counterparty adjustments
        """
        terminal_prices = np.linspace(
            spot * lower_spot_multiplier,
            spot * upper_spot_multiplier,
            number_of_points,
        )
    
        stock_value_per_share = terminal_prices
    
        long_put_value_per_share = np.maximum(
            put_strike - terminal_prices,
            0,
        )
    
        short_call_value_per_share = -np.maximum(
            terminal_prices - call_strike,
            0,
        )
    
        net_option_premium_per_share = (
            call_premium - put_premium
        )
    
        collar_value_per_share = (
            stock_value_per_share
            + long_put_value_per_share
            + short_call_value_per_share
            + net_option_premium_per_share
        )
    
        return pd.DataFrame(
            {
                "Terminal_Stock_Price": terminal_prices,
                "Unhedged_Value": (
                    terminal_prices * shares
                ),
                "Collar_Value": (
                    collar_value_per_share * shares
                ),
                "Put_Value": (
                    long_put_value_per_share * shares
                ),
                "Short_Call_Value": (
                    short_call_value_per_share * shares
                ),
            }
        )
    
    
    # ------------------------------------------------------------
    # 5. CREATE THE BLOOMBERG UNIVERSE
    # ------------------------------------------------------------
    
    universe = bq.univ.list(TICKERS)
    
    print(f"Universe created with {len(TICKERS)} securities.")
    
    
    # ------------------------------------------------------------
    # 6. SET HISTORICAL DATE RANGE
    # ------------------------------------------------------------
    
    date_range = bq.func.range(
        "-1Y",
        "0D",
    )
    
    
    # ------------------------------------------------------------
    # 7. REQUEST HISTORICAL PRICES
    #
    # Price may be forward-filled so non-trading calendar observations
    # can retain the most recent stock price.
    # ------------------------------------------------------------
    
    price_request = bql.Request(
        universe,
        {
            "Price": bq.data.px_last(
                dates=date_range,
                fill="prev",
            )
        },
    )
    
    print("Requesting historical price data...")
    
    price_response = bq.execute(
        price_request
    )
    
    price_df = bql.combined_df(
        price_response
    ).reset_index()
    
    price_df = flatten_columns(
        price_df
    )
    
    print("Historical price data returned.")
    print("Price columns:")
    print(price_df.columns.tolist())
    
    
    # ------------------------------------------------------------
    # 8. REQUEST HISTORICAL VOLUME
    #
    # Do not use fill='prev' for volume.
    # A non-trading day should not inherit the prior day's volume.
    # ------------------------------------------------------------
    
    volume_request = bql.Request(
        universe,
        {
            "Volume": bq.data.px_volume(
                dates=date_range,
            )
        },
    )
    
    print("\nRequesting historical volume data...")
    
    volume_response = bq.execute(
        volume_request
    )
    
    volume_df = bql.combined_df(
        volume_response
    ).reset_index()
    
    volume_df = flatten_columns(
        volume_df
    )
    
    print("Historical volume data returned.")
    print("Volume columns:")
    print(volume_df.columns.tolist())
    
    
    # ------------------------------------------------------------
    # 9. IDENTIFY PRICE RESPONSE COLUMNS
    # ------------------------------------------------------------
    
    price_ticker_column = identify_column(
        price_df.columns,
        possible_terms=[
            "id",
            "security",
            "ticker",
        ],
        exclude_terms=[
            "currency",
        ],
    )
    
    price_date_column = identify_column(
        price_df.columns,
        possible_terms=[
            "date",
        ],
    )
    
    price_value_column = identify_column(
        price_df.columns,
        possible_terms=[
            "price",
            "px_last",
        ],
    )
    
    
    # ------------------------------------------------------------
    # 10. IDENTIFY VOLUME RESPONSE COLUMNS
    # ------------------------------------------------------------
    
    volume_ticker_column = identify_column(
        volume_df.columns,
        possible_terms=[
            "id",
            "security",
            "ticker",
        ],
        exclude_terms=[
            "currency",
        ],
    )
    
    volume_date_column = identify_column(
        volume_df.columns,
        possible_terms=[
            "date",
        ],
    )
    
    volume_value_column = identify_column(
        volume_df.columns,
        possible_terms=[
            "volume",
            "px_volume",
        ],
    )
    
    
    # ------------------------------------------------------------
    # 11. VALIDATE RETURNED COLUMN NAMES
    # ------------------------------------------------------------
    
    required_columns = {
        "price ticker column": price_ticker_column,
        "price date column": price_date_column,
        "price value column": price_value_column,
        "volume ticker column": volume_ticker_column,
        "volume date column": volume_date_column,
        "volume value column": volume_value_column,
    }
    
    missing_columns = [
        name
        for name, column in required_columns.items()
        if column is None
    ]
    
    if missing_columns:
        raise ValueError(
            "Could not identify these returned Bloomberg columns: "
            + ", ".join(missing_columns)
            + "\n\nPrice columns returned: "
            + str(price_df.columns.tolist())
            + "\n\nVolume columns returned: "
            + str(volume_df.columns.tolist())
        )
    
    print("\nDetected Bloomberg columns:")
    print(f"Price ticker: {price_ticker_column}")
    print(f"Price date:   {price_date_column}")
    print(f"Price value:  {price_value_column}")
    print(f"Volume ticker: {volume_ticker_column}")
    print(f"Volume date:   {volume_date_column}")
    print(f"Volume value:  {volume_value_column}")
    
    
    # ------------------------------------------------------------
    # 12. CLEAN PRICE DATA
    # ------------------------------------------------------------
    
    price_history = price_df[
        [
            price_ticker_column,
            price_date_column,
            price_value_column,
        ]
    ].copy()
    
    price_history.columns = [
        "Ticker",
        "Date",
        "Price",
    ]
    
    price_history["Ticker"] = (
        price_history["Ticker"]
        .astype(str)
        .str.strip()
    )
    
    price_history["Date"] = pd.to_datetime(
        price_history["Date"],
        errors="coerce",
    )
    
    price_history["Price"] = pd.to_numeric(
        price_history["Price"],
        errors="coerce",
    )
    
    price_history = price_history.dropna(
        subset=[
            "Ticker",
            "Date",
            "Price",
        ]
    )
    
    price_history = price_history.drop_duplicates(
        subset=[
            "Ticker",
            "Date",
        ],
        keep="last",
    )
    
    price_history = price_history.sort_values(
        [
            "Ticker",
            "Date",
        ]
    ).reset_index(drop=True)
    
    
    # ------------------------------------------------------------
    # 13. CLEAN VOLUME DATA
    # ------------------------------------------------------------
    
    volume_history = volume_df[
        [
            volume_ticker_column,
            volume_date_column,
            volume_value_column,
        ]
    ].copy()
    
    volume_history.columns = [
        "Ticker",
        "Date",
        "Volume",
    ]
    
    volume_history["Ticker"] = (
        volume_history["Ticker"]
        .astype(str)
        .str.strip()
    )
    
    volume_history["Date"] = pd.to_datetime(
        volume_history["Date"],
        errors="coerce",
    )
    
    volume_history["Volume"] = pd.to_numeric(
        volume_history["Volume"],
        errors="coerce",
    )
    
    volume_history = volume_history.dropna(
        subset=[
            "Ticker",
            "Date",
            "Volume",
        ]
    )
    
    # Negative volume observations should not be used.
    volume_history = volume_history[
        volume_history["Volume"] >= 0
    ]
    
    volume_history = volume_history.drop_duplicates(
        subset=[
            "Ticker",
            "Date",
        ],
        keep="last",
    )
    
    volume_history = volume_history.sort_values(
        [
            "Ticker",
            "Date",
        ]
    ).reset_index(drop=True)
    
    
    # ------------------------------------------------------------
    # 14. DIAGNOSTIC CHECKS BEFORE MERGING
    # ------------------------------------------------------------
    
    print("\nPRICE DATA CHECK")
    print("Price observations:", len(price_history))
    print(
        "Securities with price data:",
        price_history["Ticker"].nunique(),
    )
    
    print("\nVOLUME DATA CHECK")
    print("Volume observations:", len(volume_history))
    print(
        "Securities with volume data:",
        volume_history["Ticker"].nunique(),
    )
    
    print("\nVolume observations by ticker:")
    
    volume_counts_before_merge = (
        volume_history
        .groupby("Ticker")["Volume"]
        .count()
        .sort_values()
    )
    
    display(
        volume_counts_before_merge
        .rename("Volume Observation Count")
        .to_frame()
    )
    
    if volume_history.empty:
        raise ValueError(
            "The historical-volume request returned no usable data. "
            "Inspect volume_df directly to confirm its returned values."
        )
    
    
    # ------------------------------------------------------------
    # 15. NORMALIZE DATES BEFORE MERGING
    #
    # This removes time-of-day information that can prevent matching.
    # ------------------------------------------------------------
    
    price_history["Date"] = (
        price_history["Date"]
        .dt.normalize()
    )
    
    volume_history["Date"] = (
        volume_history["Date"]
        .dt.normalize()
    )
    
    
    # ------------------------------------------------------------
    # 16. MERGE PRICE AND VOLUME
    # ------------------------------------------------------------
    
    history = pd.merge(
        price_history,
        volume_history,
        on=[
            "Ticker",
            "Date",
        ],
        how="left",
        validate="one_to_one",
    )
    
    history = history.sort_values(
        [
            "Ticker",
            "Date",
        ]
    ).reset_index(drop=True)
    
    
    # ------------------------------------------------------------
    # 17. CHECK MERGE QUALITY
    # ------------------------------------------------------------
    
    print("\nMERGED DATA CHECK")
    print("Merged observations:", len(history))
    print(
        "Non-null volume observations:",
        history["Volume"].notna().sum(),
    )
    
    print("\nNon-null merged volume observations by ticker:")
    
    merged_volume_counts = (
        history
        .groupby("Ticker")["Volume"]
        .count()
        .sort_values()
    )
    
    display(
        merged_volume_counts
        .rename("Merged Volume Count")
        .to_frame()
    )
    
    merge_quality = (
        history
        .groupby("Ticker")
        .agg(
            Price_Observations=("Price", "count"),
            Volume_Observations=("Volume", "count"),
        )
    )
    
    merge_quality["Volume_Match_Rate"] = (
        merge_quality["Volume_Observations"]
        / merge_quality["Price_Observations"]
    )
    
    print("\nPrice-volume merge quality:")
    
    display(
        merge_quality
    )
    
    
    # ------------------------------------------------------------
    # 18. FALLBACK IF EXACT DATE MERGE FAILS
    #
    # If price dates and volume dates differ slightly because of
    # timestamps, use merge_asof within each ticker.
    # ------------------------------------------------------------
    
    if history["Volume"].notna().sum() == 0:
    
        print(
            "\nWarning: exact date merge produced no volume matches."
        )
    
        print(
            "Attempting ticker-by-ticker nearest-date merge..."
        )
    
        merged_groups = []
    
        for ticker in price_history["Ticker"].unique():
    
            ticker_prices = (
                price_history[
                    price_history["Ticker"] == ticker
                ]
                .sort_values("Date")
                .copy()
            )
    
            ticker_volumes = (
                volume_history[
                    volume_history["Ticker"] == ticker
                ]
                .sort_values("Date")
                .copy()
            )
    
            ticker_prices = ticker_prices.drop(
                columns=["Ticker"]
            )
    
            ticker_volumes = ticker_volumes.drop(
                columns=["Ticker"]
            )
    
            if ticker_volumes.empty:
                ticker_prices["Volume"] = np.nan
    
            else:
                ticker_prices = pd.merge_asof(
                    ticker_prices,
                    ticker_volumes,
                    on="Date",
                    direction="nearest",
                    tolerance=pd.Timedelta("12H"),
                )
    
            ticker_prices["Ticker"] = ticker
    
            merged_groups.append(
                ticker_prices
            )
    
        history = pd.concat(
            merged_groups,
            ignore_index=True,
        )
    
        history = history[
            [
                "Ticker",
                "Date",
                "Price",
                "Volume",
            ]
        ]
    
        history = history.sort_values(
            [
                "Ticker",
                "Date",
            ]
        ).reset_index(drop=True)
    
        print(
            "Non-null volume observations after fallback:",
            history["Volume"].notna().sum(),
        )
    
    
    # ------------------------------------------------------------
    # 19. DISPLAY SAMPLE MERGED DATA
    # ------------------------------------------------------------
    
    print("\nSample merged historical data:")
    
    display(
        history.tail(20)
    )
    
    
    # ------------------------------------------------------------
    # 20. CALCULATE SECURITY METRICS
    # ------------------------------------------------------------
    
    security_metrics = []
    
    for ticker, ticker_history in history.groupby("Ticker"):
    
        ticker_history = (
            ticker_history
            .sort_values("Date")
            .copy()
        )
    
        valid_price_history = ticker_history.dropna(
            subset=["Price"]
        ).copy()
    
        valid_volume_history = ticker_history.dropna(
            subset=["Volume"]
        ).copy()
    
        prices = valid_price_history["Price"]
    
        if len(prices) < 30:
            print(
                f"Skipping {ticker}: only "
                f"{len(prices)} usable price observations."
            )
            continue
    
        current_price = prices.iloc[-1]
    
        # Use up to the latest 252 observations.
        trailing_52_week_prices = prices.tail(252)
    
        high_52_week = trailing_52_week_prices.max()
        low_52_week = trailing_52_week_prices.min()
    
        if (
            pd.notna(high_52_week)
            and high_52_week != 0
        ):
            pct_below_high = (
                (high_52_week - current_price)
                / high_52_week
            ) * 100
        else:
            pct_below_high = np.nan
    
        daily_returns = prices.pct_change()
    
        realized_vol_20d = annualized_realized_volatility(
            daily_returns,
            window=20,
        )
    
        realized_vol_60d = annualized_realized_volatility(
            daily_returns,
            window=60,
        )
    
        # Approximately 63 trading days in three months.
        if len(prices) >= 64:
            return_3m = (
                current_price
                / prices.iloc[-64]
            ) - 1
        else:
            return_3m = np.nan
    
        # Approximately 126 trading days in six months.
        if len(prices) >= 127:
            return_6m = (
                current_price
                / prices.iloc[-127]
            ) - 1
        else:
            return_6m = np.nan
    
        if len(prices) >= 252:
            return_1y = (
                current_price
                / prices.iloc[-252]
            ) - 1
        else:
            return_1y = (
                current_price
                / prices.iloc[0]
            ) - 1
    
        # --------------------------------------------------------
        # Volume metrics
        # --------------------------------------------------------
    
        if valid_volume_history.empty:
    
            average_volume_20d = np.nan
            average_volume_60d = np.nan
            average_daily_value_traded_20d = np.nan
            volume_observation_count = 0
    
        else:
    
            valid_volume_history = (
                valid_volume_history
                .sort_values("Date")
                .copy()
            )
    
            average_volume_20d = (
                valid_volume_history["Volume"]
                .tail(20)
                .mean()
            )
    
            average_volume_60d = (
                valid_volume_history["Volume"]
                .tail(60)
                .mean()
            )
    
            valid_volume_history["Daily_Value_Traded"] = (
                valid_volume_history["Price"]
                * valid_volume_history["Volume"]
            )
    
            average_daily_value_traded_20d = (
                valid_volume_history[
                    "Daily_Value_Traded"
                ]
                .dropna()
                .tail(20)
                .mean()
            )
    
            volume_observation_count = len(
                valid_volume_history
            )
    
        security_metrics.append(
            {
                "Ticker": ticker,
                "Price": current_price,
                "52W_High": high_52_week,
                "52W_Low": low_52_week,
                "Pct_Below_52W_High": pct_below_high,
                "Realized_Vol_20D": realized_vol_20d,
                "Realized_Vol_60D": realized_vol_60d,
                "Return_3M": return_3m,
                "Return_6M": return_6m,
                "Return_1Y": return_1y,
                "Average_Volume_20D": average_volume_20d,
                "Average_Volume_60D": average_volume_60d,
                "Average_Daily_Value_Traded_20D": (
                    average_daily_value_traded_20d
                ),
                "Last_Data_Date": (
                    valid_price_history["Date"].max()
                ),
                "Price_Observation_Count": len(
                    valid_price_history
                ),
                "Volume_Observation_Count": (
                    volume_observation_count
                ),
            }
        )
    
    
    # ------------------------------------------------------------
    # 21. CREATE METRICS DATAFRAME
    # ------------------------------------------------------------
    
    metrics = pd.DataFrame(
        security_metrics
    )
    
    if metrics.empty:
        raise ValueError(
            "No usable security metrics were produced."
        )
    
    print("\nRaw calculated metrics:")
    
    display(
        metrics
    )
    
    
    # ------------------------------------------------------------
    # 22. DIAGNOSE ANY REMAINING VOLUME NULLS
    # ------------------------------------------------------------
    
    missing_volume_metrics = metrics[
        metrics["Average_Volume_20D"].isna()
    ]
    
    if not missing_volume_metrics.empty:
    
        print(
            "\nWarning: these securities still have no usable "
            "20-day volume metric:"
        )
    
        display(
            missing_volume_metrics[
                [
                    "Ticker",
                    "Volume_Observation_Count",
                ]
            ]
        )
    
    else:
    
        print(
            "\n20-day average volume was calculated "
            "successfully for all securities."
        )
    
    
    # ------------------------------------------------------------
    # 23. CREATE FACTOR SCORES
    # ------------------------------------------------------------
    
    metrics["High_Proximity_Score"] = percentile_score(
        metrics["Pct_Below_52W_High"],
        higher_is_better=False,
    )
    
    metrics["Volatility_Score"] = percentile_score(
        metrics["Realized_Vol_20D"],
        higher_is_better=True,
    )
    
    metrics["Recent_Return_Score"] = percentile_score(
        metrics["Return_3M"],
        higher_is_better=True,
    )
    
    metrics["Liquidity_Score"] = percentile_score(
        metrics["Average_Daily_Value_Traded_20D"],
        higher_is_better=True,
    )
    
    
    # ------------------------------------------------------------
    # 24. CALCULATE OPPORTUNITY SCORE
    #
    # Use a weighted average of available factor scores rather than
    # allowing one missing field to make the entire score NaN.
    # ------------------------------------------------------------
    
    factor_definitions = {
        "High_Proximity_Score": WEIGHTS["high_proximity"],
        "Volatility_Score": WEIGHTS["realized_volatility"],
        "Recent_Return_Score": WEIGHTS["recent_return"],
        "Liquidity_Score": WEIGHTS["liquidity"],
    }
    
    
    def calculate_weighted_available_score(row):
        weighted_sum = 0.0
        available_weight = 0.0
    
        for factor, weight in factor_definitions.items():
            value = row.get(factor)
    
            if pd.notna(value):
                weighted_sum += value * weight
                available_weight += weight
    
        if available_weight == 0:
            return np.nan
    
        return weighted_sum / available_weight
    
    
    metrics["Opportunity_Score"] = metrics.apply(
        calculate_weighted_available_score,
        axis=1,
    )
    
    
    # ------------------------------------------------------------
    # 25. ADD READABLE EXPLANATIONS
    # ------------------------------------------------------------
    
    metrics["Why_Flagged"] = metrics.apply(
        create_reason,
        axis=1,
    )
    
    
    # ------------------------------------------------------------
    # 26. RANK RESULTS
    # ------------------------------------------------------------
    
    results = metrics.sort_values(
        "Opportunity_Score",
        ascending=False,
        na_position="last",
    ).reset_index(drop=True)
    
    results.index = results.index + 1
    results.index.name = "Rank"
    
    
    # ------------------------------------------------------------
    # 27. BUILD DISPLAY TABLE
    # ------------------------------------------------------------
    
    display_results = results[
        [
            "Ticker",
            "Price",
            "Pct_Below_52W_High",
            "Realized_Vol_20D",
            "Return_3M",
            "Average_Volume_20D",
            "Average_Daily_Value_Traded_20D",
            "Opportunity_Score",
            "Why_Flagged",
        ]
    ].copy()
    
    display_results["Price"] = (
        display_results["Price"]
        .round(2)
    )
    
    display_results["Pct_Below_52W_High"] = (
        display_results["Pct_Below_52W_High"]
        .round(1)
    )
    
    display_results["Realized_Vol_20D"] = (
        display_results["Realized_Vol_20D"]
        * 100
    ).round(1)
    
    display_results["Return_3M"] = (
        display_results["Return_3M"]
        * 100
    ).round(1)
    
    display_results["Average_Volume_20D"] = (
        display_results["Average_Volume_20D"]
        / 1_000_000
    ).round(2)
    
    display_results[
        "Average_Daily_Value_Traded_20D"
    ] = (
        display_results[
            "Average_Daily_Value_Traded_20D"
        ]
        / 1_000_000
    ).round(1)
    
    display_results["Opportunity_Score"] = (
        display_results["Opportunity_Score"]
        .round(1)
    )
    
    display_results = display_results.rename(
        columns={
            "Pct_Below_52W_High":
                "% Below 52W High",
    
            "Realized_Vol_20D":
                "20D Realized Vol (%)",
    
            "Return_3M":
                "3M Return (%)",
    
            "Average_Volume_20D":
                "20D Avg Volume (mm shares)",
    
            "Average_Daily_Value_Traded_20D":
                "20D Avg Daily Value Traded ($mm)",
    
            "Opportunity_Score":
                "Opportunity Score",
    
            "Why_Flagged":
                "Why Flagged",
        }
    )
    
    
    # ------------------------------------------------------------
    # 28. DISPLAY RANKED OPPORTUNITIES
    # ------------------------------------------------------------
    
    print("\nTOP STRATEGIC EQUITY OPPORTUNITY CANDIDATES")
    
    display(
        display_results.head(TOP_N)
    )
    
    
    # ------------------------------------------------------------
    # 29. OPPORTUNITY SCORE CHART
    # ------------------------------------------------------------
    
    chart_results = (
        results
        .dropna(subset=["Opportunity_Score"])
        .head(TOP_N)
        .sort_values(
            "Opportunity_Score",
            ascending=True,
        )
    )
    
    score_chart = go.Figure()
    
    score_chart.add_trace(
        go.Bar(
            x=chart_results["Opportunity_Score"],
            y=chart_results["Ticker"],
            orientation="h",
            text=(
                chart_results[
                    "Opportunity_Score"
                ].round(1)
            ),
            textposition="outside",
            customdata=chart_results[
                [
                    "Pct_Below_52W_High",
                    "Realized_Vol_20D",
                    "Return_3M",
                    "Average_Volume_20D",
                    "Why_Flagged",
                ]
            ],
            hovertemplate=(
                "<b>%{y}</b><br>"
                "Opportunity score: %{x:.1f}<br>"
                "Below 52W high: %{customdata[0]:.1f}%<br>"
                "20D realized vol: %{customdata[1]:.1%}<br>"
                "Three-month return: %{customdata[2]:.1%}<br>"
                "20D avg volume: %{customdata[3]:,.0f}<br>"
                "%{customdata[4]}"
                "<extra></extra>"
            ),
        )
    )
    
    score_chart.update_layout(
        title="Strategic Equity Opportunity Ranking",
        xaxis_title="Opportunity Score",
        yaxis_title="Security",
        height=max(
            450,
            TOP_N * 45,
        ),
        margin=dict(
            l=120,
            r=80,
            t=80,
            b=60,
        ),
    )
    
    score_chart.show()
    
    
    # ------------------------------------------------------------
    # 30. SELECT TOP NAME FOR COLLAR ANALYSIS
    # ------------------------------------------------------------
    
    valid_results = results.dropna(
        subset=[
            "Opportunity_Score",
            "Price",
        ]
    )
    
    if valid_results.empty:
        raise ValueError(
            "No security has both a valid opportunity score "
            "and a valid current price."
        )
    
    selected_ticker = (
        valid_results.iloc[0]["Ticker"]
    )
    
    selected_spot = safe_float(
        valid_results.iloc[0]["Price"]
    )
    
    put_strike = (
        selected_spot
        * DEFAULT_PUT_STRIKE_PCT
    )
    
    call_strike = (
        selected_spot
        * DEFAULT_CALL_STRIKE_PCT
    )
    
    print("\nILLUSTRATIVE COLLAR")
    print(f"Selected security: {selected_ticker}")
    print(f"Current stock price: {selected_spot:,.2f}")
    print(f"Illustrative put strike: {put_strike:,.2f}")
    print(f"Illustrative call strike: {call_strike:,.2f}")
    print(f"Illustrative share count: {DEFAULT_SHARES:,.0f}")
    
    
    # ------------------------------------------------------------
    # 31. CALCULATE COLLAR PAYOFF
    # ------------------------------------------------------------
    
    payoff = collar_payoff(
        spot=selected_spot,
        put_strike=put_strike,
        call_strike=call_strike,
        shares=DEFAULT_SHARES,
        put_premium=0.0,
        call_premium=0.0,
    )
    
    
    # ------------------------------------------------------------
    # 32. PLOT COLLAR PAYOFF
    # ------------------------------------------------------------
    
    payoff_chart = go.Figure()
    
    payoff_chart.add_trace(
        go.Scatter(
            x=payoff["Terminal_Stock_Price"],
            y=payoff["Unhedged_Value"],
            mode="lines",
            name="Unhedged Stock Position",
            hovertemplate=(
                "Terminal stock price: %{x:,.2f}<br>"
                "Position value: $%{y:,.0f}"
                "<extra></extra>"
            ),
        )
    )
    
    payoff_chart.add_trace(
        go.Scatter(
            x=payoff["Terminal_Stock_Price"],
            y=payoff["Collar_Value"],
            mode="lines",
            name="Illustrative Collar",
            hovertemplate=(
                "Terminal stock price: %{x:,.2f}<br>"
                "Collar value: $%{y:,.0f}"
                "<extra></extra>"
            ),
        )
    )
    
    payoff_chart.add_vline(
        x=selected_spot,
        line_dash="dot",
        annotation_text="Current Price",
        annotation_position="top",
    )
    
    payoff_chart.add_vline(
        x=put_strike,
        line_dash="dash",
        annotation_text="Put Strike",
        annotation_position="bottom left",
    )
    
    payoff_chart.add_vline(
        x=call_strike,
        line_dash="dash",
        annotation_text="Call Strike",
        annotation_position="bottom right",
    )
    
    payoff_chart.update_layout(
        title=(
            f"{selected_ticker}: Illustrative "
            f"{DEFAULT_PUT_STRIKE_PCT:.0%}–"
            f"{DEFAULT_CALL_STRIKE_PCT:.0%} Collar"
        ),
        xaxis_title="Stock Price at Maturity",
        yaxis_title="Terminal Position Value",
        hovermode="x unified",
        height=600,
    )
    
    payoff_chart.show()
    
    
    # ------------------------------------------------------------
    # 33. CREATE TERMINAL SCENARIO TABLE
    # ------------------------------------------------------------
    
    scenario_prices = [
        selected_spot * 0.50,
        selected_spot * 0.75,
        put_strike,
        selected_spot,
        call_strike,
        selected_spot * 1.25,
        selected_spot * 1.50,
    ]
    
    scenario_rows = []
    
    for terminal_price in scenario_prices:
    
        unhedged_value = (
            terminal_price
            * DEFAULT_SHARES
        )
    
        collar_value = (
            terminal_price
            + max(
                put_strike - terminal_price,
                0,
            )
            - max(
                terminal_price - call_strike,
                0,
            )
        ) * DEFAULT_SHARES
    
        scenario_rows.append(
            {
                "Terminal Stock Price": terminal_price,
                "Unhedged Position Value": unhedged_value,
                "Collar Position Value": collar_value,
                "Collar Minus Unhedged": (
                    collar_value - unhedged_value
                ),
            }
        )
    
    scenario_table = pd.DataFrame(
        scenario_rows
    )
    
    scenario_table["Terminal Stock Price"] = (
        scenario_table["Terminal Stock Price"]
        .round(2)
    )
    
    for column in [
        "Unhedged Position Value",
        "Collar Position Value",
        "Collar Minus Unhedged",
    ]:
        scenario_table[column] = (
            scenario_table[column]
            .round(0)
        )
    
    print("\nILLUSTRATIVE TERMINAL-SCENARIO TABLE")
    
    display(
        scenario_table
    )
    
    
    # ------------------------------------------------------------
    # 34. FINAL STATUS
    # ------------------------------------------------------------
    
    print(
        "\nScreen complete. Results are illustrative and "
        "intended for idea generation only."
    )


return results, history
